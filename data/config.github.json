{
  "version": "1.0",
  "ai": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-6",
    "api_key_env": "ANTHROPIC_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "xxx@qq.com",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 20,
      "min_score": 100
    },
    "rss": [
      { "name": "Schneier on Security", "url": "https://www.schneier.com/feed/atom/" },
      { "name": "Detection Engineering", "url": "https://www.detectionengineering.net/feed"},
      { "name": "Daniel Miessler", "url": "https://danielmiessler.com/feed/"},
      { "name": "Bleeping Computer", "url": "https://www.bleepingcomputer.com/feed/", "category": "cyber"},
      { "name": "Security News | VentureBeat", "url": "https://venturebeat.com/category/security/feed/", "category": "cyber"},
      { "name": "Krebs on Security", "url": "https://krebsonsecurity.com/feed/", "category": "cyber"},
      { "name": "The Register Security", "url": "https://www.theregister.com/security/headlines.atom", "category": "cyber"},
      { "name": "Trail of Bits Blog", "url" :"https://blog.trailofbits.com/feed/", "category": "cyber"},
      { "name": "CISA Advisories", "url": "https://www.cisa.gov/news.xml", "category": "cyber"},
      { "name": "Dark Reading", "url": "https://www.darkreading.com/rss.xml", "category": "cyber"},
      { "name": "tl;dr sec", "url": "https://tldrsec.com/feed"},
      { "name": "Unit 42", "url": "https://unit42.paloaltonetworks.com/feed/"},
      { "name": "WeLiveSecurity", "url": "https://www.welivesecurity.com/en/rss/feed/"},
      { "name": "security – Ars Technica", "url": "https://arstechnica.com/tag/security/feed"},
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        }
      ],
      "fetch_comments": 5
    },
    "twitter": {
      "enabled": false,
      "users": ["cyb3rops", "clintgibler"],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
  "filtering": {
    "ai_score_threshold": 7.5,
    "time_window_hours": 24,
    "max_items": null,
    "category_groups": {},
    "default_group": "other",
    "default_group_limit": null
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null,
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "Horizon生成结果: #{result}\nHorizon日报重要资讯数量: #{important_items}/#{all_items}"
            },
            {
              "tag": "hr"
            },
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
